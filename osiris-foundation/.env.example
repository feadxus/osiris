# ── OSIRIS Foundation (Phase 0) ──────────────────────────────
# Copy to .env next to docker-compose.foundation.yml and edit.

# Postgres (relational + vector + graph)
POSTGRES_PASSWORD=change_me_strong
POSTGRES_PORT=5432

# MinIO (raw blob storage)
MINIO_USER=osiris
MINIO_PASSWORD=change_me_strong
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Meilisearch (full-text)
MEILI_MASTER_KEY=change_me_strong
MEILI_PORT=7700

# Redis (queue/cache, used in Phase 2)
REDIS_PORT=6379

# Yente (self-hosted OpenSanctions)
YENTE_PORT=8000

# ── Connection string the OSIRIS app will use (Phase 1) ──────
# DATABASE_URL=postgresql://osiris:change_me_strong@db:5432/osiris
# EMBEDDING_MODEL=nomic-embed-text   # served by your Ollama instance
